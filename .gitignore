# IDE
.idea/
.vscode/
*.swp
*.swo
*~

# macOS
.DS_Store

# Secrets and sensitive files
*.pem
*.key
secrets/
.env
.env.*
!.env.example
.envrc

# AWS
.aws/

# Parameters with sensitive data
cloudformation/parameters/*-secrets.json

# Terraform (if used later)
*.tfstate
*.tfstate.backup
.terraform/

# Python
__pycache__/
*.pyc
*.pyo
venv/

# Logs (but keep PROMPT_LOGS/ for audit trail)
*.log
PROMPT_LOGS/.current_prompt
PROMPT_LOGS/.last_commit_hash

# Temporary files
tmp/
temp/

# Obsidian volatile state
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache/

# Common engineering noise
.git/
node_modules/
vendor/
dist/
build/
