-- ============================================================
-- migration/pgloader/zinew.load.tmpl
--
-- pgloader spec: local MariaDB scratch DB (populated by
-- restore-mysql.sh) -> sandbox RDS PostgreSQL.
--
-- This is a TEMPLATE — variable references (${...}) are resolved by
-- migration/scripts/deploy-host/run-pgloader.sh via envsubst before
-- pgloader is invoked. Do NOT invoke pgloader on this file directly;
-- run-pgloader.sh handles env sourcing, rendering, chmod 600, and
-- shredding the rendered file after the run.
--
-- Source: mysql://worxco:localscratchpass@127.0.0.1:3306/zinew
--   - worxco/localscratchpass are scratch-DB credentials created by
--     restore-mysql.sh; not sensitive.
--   - 127.0.0.1 (not localhost/socket) — pgloader's qmynd driver
--     needs TCP + mysql_native_password.
--
-- Target: postgresql://.../${DRUPAL_DB_NAME}?sslmode=require
--   - Values come from /etc/worxco/envs/sandbox (populated by
--     refresh-env-config from SSM).
--   - SANDBOX_PW_ENC is the URL-encoded form of the master password.
--     run-pgloader.sh computes it from SANDBOX_PW if missing.
--   - Schema `zinew` comes from Drupal's own settings.php, not
--     pgloader — pgloader writes to the default (public) schema.
--
-- WITH clause tuning (baked in from second successful migration run):
--   - batch/prefetch = 250 (down from pgloader defaults of ~25000/1000)
--     After first-run OOM at defaults, dropping to 250 kept memory
--     pressure well below the 4 GB SBCL heap.
--   - workers = 2, concurrency = 1
--     One table at a time, two worker threads. Slower than default
--     parallelism but predictable memory footprint.
--   - include drop, create tables/indexes, reset sequences, foreign keys
--     Full destructive rebuild of the target — safe because the target
--     is a scratch/staging DB, never prod.
--   - downcase identifiers
--     MySQL is case-insensitive by default; postgres is case-sensitive.
--     Downcasing keeps Drupal's PDO queries happy without needing quotes.
--
-- CAST clauses (unchanged since first working version):
--   - tinyint(1) -> boolean (Drupal's boolean-ish int columns)
--   - datetime/date/timestamp with zero-date sanitizer (MariaDB allows
--     '0000-00-00' which postgres rejects; zero-dates-to-null helper
--     converts them to NULL before insert).
-- ============================================================

LOAD DATABASE
  FROM mysql://worxco:localscratchpass@127.0.0.1:3306/zinew
  INTO postgresql://${DRUPAL_DB_USER}:${SANDBOX_PW_ENC}@${DRUPAL_DB_HOST}:${DRUPAL_DB_PORT}/${DRUPAL_DB_NAME}?sslmode=require

  WITH include drop,
       create tables,
       create indexes,
       reset sequences,
       foreign keys,
       downcase identifiers,
       batch rows = 250,
       prefetch rows = 250,
       workers = 2,
       concurrency = 1

  CAST type tinyint when (= 1 precision) to boolean drop typemod using tinyint-to-boolean,
       type datetime to timestamptz drop default drop not null using zero-dates-to-null,
       type date drop not null drop default using zero-dates-to-null,
       type timestamp drop default drop not null using zero-dates-to-null
;
