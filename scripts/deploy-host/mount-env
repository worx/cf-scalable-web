#
# mount-env: Mount a project's FSx OpenZFS for the named environment.
# Installed at /usr/local/sbin/mount-env (requires sudo to mount).
# Usage: sudo mount-env sandbox

set -euo pipefail

if [ "$#" -lt 1 ]; then
  echo "Usage: mount-env <environment>"
  echo "Mounts /var/www/<env> from FSx OpenZFS for the named environment."
  echo "Example: sudo mount-env sandbox"
  exit 1
fi
ENV="$1"

MOUNT_POINT="/var/www/$ENV"
if mountpoint -q "$MOUNT_POINT" 2>/dev/null; then
  echo "$MOUNT_POINT is already mounted"
  exit 0
fi

FSX_DNS=$(aws ssm get-parameter \
  --name "/$ENV/fsx/dns-name" \
  --query 'Parameter.Value' \
  --output text 2>/dev/null) || {
  echo "ERROR: SSM parameter /$ENV/fsx/dns-name not found."
  echo "FSx for environment '$ENV' may not be deployed yet,"
  echo "or VPC peering (cf-deploy-peering) is not in place."
  exit 1
}

mkdir -p "$MOUNT_POINT"
mount -t nfs4 -o vers=4.1,port=2049 "$FSX_DNS:/fsx" "$MOUNT_POINT"
echo "Mounted $FSX_DNS:/fsx -> $MOUNT_POINT"

# Persist the mount in /etc/fstab so it survives stop/start of the EC2
# instance (fstab is on the EBS root volume which persists). Each env
# gets its own marker comment so re-runs cleanly replace stale entries.
#
# Mount options:
#   vers=4.1,port=2049   matches our manual mount (NFSv4.1 on TCP 2049)
#   nofail               don't hang boot if FSx is unreachable (e.g.,
#                        peering down or FSx destroyed) — boot continues
#                        and the user can run mount-env again to fix
#   _netdev              wait for network before attempting this mount
#   noatime              don't update access times (small write reduction)
FSTAB_TAG="# worxco-mount-env: $ENV"
FSTAB_LINE="$FSX_DNS:/fsx $MOUNT_POINT nfs4 vers=4.1,port=2049,nofail,_netdev,noatime 0 0"

# Remove any existing entry for this env (the marker line plus the next),
# then append the fresh entry.
sed -i.bak "/^# worxco-mount-env: $ENV\$/,+1d" /etc/fstab
{
  echo ""
  echo "$FSTAB_TAG"
  echo "$FSTAB_LINE"
} >> /etc/fstab
rm -f /etc/fstab.bak
echo "Updated /etc/fstab so the mount survives stop/start"
