#
# use-env: Switch the deploy-host's active environment.
#
# Each deploy-host operates on ONE environment at a time. The mount target
# is always /var/www — the env-awareness lives in WHICH FSx is mounted,
# not WHERE. This matches the runtime fleet's mount layout exactly, so
# paths like /var/www/drupal/web are identical on every host.
#
# Operations:
#   1. Unmount /var/www (if currently mounted)
#   2. Strip any old worxco fstab entry
#   3. Look up the target env's FSx DNS via SSM
#   4. Refresh /etc/worxco/envs/<env> and /etc/hosts (refresh-env-config)
#   5. Mount the target env's FSx at /var/www
#   6. Write a new /etc/fstab entry so the mount survives stop/start
#   7. Write the env name to /etc/worxco/current-env (read by zsh RPROMPT)
#
# Installed at /usr/local/sbin/use-env (requires sudo).
# Allowed for the ubuntu user without password via /etc/sudoers.d.
#
# Usage:
#   sudo use-env <environment>   # switch to env, mount its FSx
#   sudo use-env none            # unmount, leave /var/www empty
#   sudo use-env                 # print current state (no sudo needed for this)

set -euo pipefail

CURRENT_ENV_FILE="/etc/worxco/current-env"
MOUNT_POINT="/var/www"
NGINX_MOUNT_POINT="/etc/nginx/shared"
FSTAB_TAG="# worxco-use-env"

# ----- no-arg: print current state and exit -----
if [ "$#" -eq 0 ]; then
  if [ -r "$CURRENT_ENV_FILE" ]; then
    echo "Current environment: $(< "$CURRENT_ENV_FILE")"
  else
    echo "Current environment: NONE (file $CURRENT_ENV_FILE missing)"
  fi
  # Read /proc/mounts directly (no stat() — wouldn't hang on stale NFS).
  if awk -v mp="$MOUNT_POINT" '$2==mp {found=1; exit} END{exit !found}' /proc/mounts; then
    echo "Mount:               $(awk -v mp="$MOUNT_POINT" '$2==mp{print $1,"->",$2,"("$3")"}' /proc/mounts)"
  else
    echo "Mount:               $MOUNT_POINT is not mounted"
  fi
  echo ""
  echo "Usage: sudo use-env <environment>"
  echo "       sudo use-env none       (unmount + clear)"
  exit 0
fi

# All mutating actions require root
if [ "$EUID" -ne 0 ]; then
  echo "ERROR: use-env mutates /etc/fstab and /var/www mount — run with sudo" >&2
  exit 1
fi

ENV="$1"

# ----- safety: refuse to umount if user's shell is inside /var/www -----
# umount would fail with EBUSY, but a clear up-front message is friendlier.
# We can't see the user's PWD from inside sudo, but we can look at their
# parent shell via /proc/$PPID/cwd.
if [ -e "/proc/$PPID/cwd" ]; then
  parent_cwd=$(readlink "/proc/$PPID/cwd" 2>/dev/null || true)
  case "$parent_cwd" in
    "$MOUNT_POINT"|"$MOUNT_POINT"/*)
      echo "ERROR: caller's shell is in $parent_cwd — cd elsewhere first" >&2
      echo "  cd /home/ubuntu  # (or anywhere outside $MOUNT_POINT)" >&2
      exit 1
      ;;
  esac
fi

# ----- common cleanup: unmount + clear fstab -----
# Unmount nginx submount first (it's a sub-NFS-export of the same FSx;
# unmount in reverse order — submount before parent — to avoid EBUSY).
#
# Detection uses /proc/mounts directly rather than `mountpoint -q`, because
# `mountpoint` calls stat() on the target path — and a stale NFS mount
# (server destroyed, kernel still attached) makes stat() block forever in
# D-state. Reading /proc/mounts is a pure in-kernel structure lookup and
# never blocks on the dead network filesystem.
#
# Unmount uses `umount -f -l` (force + lazy) rather than plain umount:
# - lazy (-l) detaches the mount from the namespace immediately, so the
#   path is free for re-mounting even if there are in-flight kernel
#   references to the now-gone NFS server
# - force (-f) is a hint to the NFS client to give up on retransmissions
#
# This combo handles the "destroy-all destroyed yesterday's FSx, today's
# deploy-host still has the kernel mount" case cleanly. Plain umount
# would hang waiting for an ACK from a server that no longer exists.
# Past incident: 2026-05-22 init-fsx-layout hung for 45+ min because
# `mountpoint -q` stat'd a stale mount.
is_mounted() {
  awk -v mp="$1" '$2==mp {found=1; exit} END{exit !found}' /proc/mounts
}

if is_mounted "$NGINX_MOUNT_POINT"; then
  echo "Unmounting current $NGINX_MOUNT_POINT (force + lazy)..."
  umount -f -l "$NGINX_MOUNT_POINT" || \
    echo "WARN: umount -f -l returned non-zero for $NGINX_MOUNT_POINT — proceeding anyway" >&2
fi
if is_mounted "$MOUNT_POINT"; then
  echo "Unmounting current $MOUNT_POINT (force + lazy)..."
  umount -f -l "$MOUNT_POINT" || \
    echo "WARN: umount -f -l returned non-zero for $MOUNT_POINT — proceeding anyway" >&2
fi
# Remove any prior worxco fstab block (marker line + the entries that
# follow). The block can be 1 or 2 lines depending on whether older
# use-env wrote just the /var/www mount or the newer /var/www +
# /etc/nginx/shared pair — sed-delete the marker and everything up
# until a blank line (the block's natural terminator).
if grep -q "^${FSTAB_TAG}\$" /etc/fstab 2>/dev/null; then
  sed -i.bak "/^${FSTAB_TAG}\$/,/^\$/d" /etc/fstab
  rm -f /etc/fstab.bak
fi

# ----- "none": already unmounted and cleared; just record the state -----
if [ "$ENV" = "none" ] || [ "$ENV" = "NONE" ]; then
  mkdir -p "$(dirname "$CURRENT_ENV_FILE")"
  echo "NONE" > "$CURRENT_ENV_FILE"
  echo "Done. $MOUNT_POINT is unmounted, no active environment."
  exit 0
fi

# ----- resolve target env's FSx DNS -----
FSX_DNS=$(aws ssm get-parameter \
  --name "/$ENV/fsx/dns-name" \
  --query 'Parameter.Value' \
  --output text 2>/dev/null || true)
if [ -z "$FSX_DNS" ] || [ "$FSX_DNS" = "None" ]; then
  echo "ERROR: cannot read SSM /$ENV/fsx/dns-name." >&2
  echo "       Either the env isn't deployed, VPC peering is down," >&2
  echo "       or this deploy-host lacks IAM perms for that env." >&2
  exit 1
fi

# ----- refresh /etc/worxco/envs/<env> and /etc/hosts FSx block -----
# FSx hostnames don't resolve across VPC peering — refresh-env-config
# maintains a /etc/hosts block that bridges the gap. Without it, the mount
# below would fail to resolve $FSX_DNS to a private IP.
if command -v refresh-env-config >/dev/null; then
  refresh-env-config "$ENV" || \
    echo "WARN: refresh-env-config failed; trying mount anyway (existing /etc/hosts may suffice)"
else
  echo "WARN: refresh-env-config not on PATH — /etc/hosts FSx block may be stale"
fi

# ----- mount target env's FSx — two mounts to match nginx layout -----
# /var/www gets the volume root. /etc/nginx/shared gets the /fsx/nginx
# submount, so operators on the deploy-host see vhost configs at the
# SAME path nginx instances see them. Two-mount design (rather than
# operators having to remember "/var/www/nginx/sites-enabled = what's
# at /etc/nginx/shared/sites-enabled on the runtime fleet"). Bonus:
# enables `sudo apt install nginx` + a local nginx serve for sandbox
# testing without round-tripping through AMI rebuilds.
mkdir -p "$MOUNT_POINT" "$NGINX_MOUNT_POINT"
echo "Mounting $FSX_DNS:/fsx -> $MOUNT_POINT (env=$ENV)"
mount -t nfs4 -o vers=4.1,port=2049 "$FSX_DNS:/fsx" "$MOUNT_POINT"

# On a freshly-created FSx volume, /fsx/nginx doesn't exist yet — the
# second mount below would fail with "No such file or directory" from
# the NFS server. Create the dir via the just-mounted /var/www access
# path so the FSx server has the expected layout before we ask it to
# export the subtree. Idempotent (mkdir -p), so re-runs are safe.
# init-fsx-layout (deploy-allX Phase 1) does additional layout work
# beyond this, but use-env owning its own "make my mounts succeed"
# preconditions is the right place to start.
if [ ! -d "$MOUNT_POINT/nginx" ]; then
  echo "  /fsx/nginx not yet on FSx — creating via $MOUNT_POINT/nginx"
  mkdir -p "$MOUNT_POINT/nginx/sites-enabled"
  chmod 755 "$MOUNT_POINT/nginx" "$MOUNT_POINT/nginx/sites-enabled"
fi

echo "Mounting $FSX_DNS:/fsx/nginx -> $NGINX_MOUNT_POINT"
mount -t nfs4 -o vers=4.1,port=2049 "$FSX_DNS:/fsx/nginx" "$NGINX_MOUNT_POINT"

# ----- persist in fstab for stop/start cycles -----
{
  echo ""
  echo "$FSTAB_TAG"
  echo "$FSX_DNS:/fsx $MOUNT_POINT nfs4 vers=4.1,port=2049,nofail,_netdev,noatime 0 0"
  echo "$FSX_DNS:/fsx/nginx $NGINX_MOUNT_POINT nfs4 vers=4.1,port=2049,nofail,_netdev,noatime 0 0"
  echo ""
} >> /etc/fstab

# ----- record active env (read by zsh RPROMPT every prompt cycle) -----
mkdir -p "$(dirname "$CURRENT_ENV_FILE")"
echo "$ENV" > "$CURRENT_ENV_FILE"

echo ""
echo "Active environment: $ENV"
echo "  /var/www           -> $FSX_DNS:/fsx"
echo "  /etc/nginx/shared  -> $FSX_DNS:/fsx/nginx"
echo "  /etc/worxco/current-env updated (zsh prompt will refresh next render)"
echo ""
echo "To pull env vars (DB host, secrets, etc.) into your current shell:"
echo "  source /etc/worxco/envs/$ENV"
echo "(The zsh \`use-env\` wrapper does this automatically. Direct calls to"
echo "  the binary at /usr/local/sbin/use-env don't propagate vars upward.)"
