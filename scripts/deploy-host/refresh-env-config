#
# refresh-env-config: Regenerate /etc/worxco/envs/<env> from SSM AND
# maintain /etc/hosts entries for FSx hostnames (which don't resolve
# across VPC peering even with AllowDnsResolutionFromRemoteVpc=true).
#
# Installed at /usr/local/sbin/refresh-env-config (requires sudo).
# Allowed for ubuntu user without password via /etc/sudoers.d entry.
# Usage: sudo refresh-env-config              # all known envs
#        sudo refresh-env-config sandbox      # specific env
#        sudo refresh-env-config sandbox staging

set -euo pipefail

if [ "$#" -eq 0 ]; then
  set -- sandbox staging production
fi

# Pass 1: write /etc/worxco/envs/<env> for each requested env
for ENV in "$@"; do
  RDS=$(aws ssm get-parameter --name "/$ENV/rds/endpoint" \
    --query 'Parameter.Value' --output text 2>/dev/null) || RDS=""
  FSX=$(aws ssm get-parameter --name "/$ENV/fsx/dns-name" \
    --query 'Parameter.Value' --output text 2>/dev/null) || FSX=""
  VALKEY=$(aws ssm get-parameter --name "/$ENV/cache/endpoint" \
    --query 'Parameter.Value' --output text 2>/dev/null) || VALKEY=""
  ALB=$(aws ssm get-parameter --name "/$ENV/compute/alb-dns-name" \
    --query 'Parameter.Value' --output text 2>/dev/null) || ALB=""
  if [ -z "$RDS" ] && [ -z "$FSX" ] && [ -z "$VALKEY" ]; then
    echo "Skipping $ENV (no infrastructure deployed)"
    continue
  fi
  # Fetch Drupal DB password from Secrets Manager. cf-app-drupal owns
  # this. If the stack isn't deployed yet (or the secret isn't created
  # yet), leave DB_PASS empty — drush will fail loudly rather than
  # silently auth as a user with no password.
  DB_PASS=$(aws secretsmanager get-secret-value \
    --secret-id "worxco/$ENV/drupal/db-password" \
    --query SecretString --output text 2>/dev/null) || DB_PASS=""
  # Fetch Drupal hash_salt from Secrets Manager. install-drupal.sh
  # creates this on first install (and migrates existing salt.txt
  # into SSM on re-run). If it's not there yet, leave HASH_SALT
  # empty — settings.php will fall back to reading /var/www/drupal-private/salt.txt
  # (backward compat during the file→SSM transition; see docs/memory/salt-persistence-design.md).
  HASH_SALT=$(aws secretsmanager get-secret-value \
    --secret-id "worxco/$ENV/drupal/hash-salt" \
    --query SecretString --output text 2>/dev/null) || HASH_SALT=""
  OUT="/etc/worxco/envs/$ENV"
  cat > "$OUT" << EOF_INNER
# Generated by refresh-env-config on $(date -u +'%Y-%m-%dT%H:%M:%SZ')
# Source from a shell with: source /etc/worxco/envs/$ENV
# Re-run: sudo refresh-env-config $ENV
#
# Each line uses 'export' so variables propagate to child processes
# (drush, php-fpm, etc.). Variable names match Drupal settings.php
# and PHP-FPM pool config — a single 'source' is sufficient.

# Drupal application config (matches getenv() calls in settings.php)
export ENVIRONMENT_NAME=$ENV
export DRUPAL_DB_HOST=$RDS
export DRUPAL_DB_PORT=5432
export DRUPAL_DB_NAME=drupal
export DRUPAL_DB_USER=drupal_user
# DRUPAL_DB_PASS is a secret. Sourced from Secrets Manager
# (worxco/$ENV/drupal/db-password) at refresh time. Re-run
# refresh-env-config after rotating the secret to update this cache.
export DRUPAL_DB_PASS=$DB_PASS
# DRUPAL_HASH_SALT is a secret. Sourced from Secrets Manager
# (worxco/$ENV/drupal/hash-salt) at refresh time. settings.php uses
# this to sign form tokens, password reset URLs, image style URLs,
# etc. Cross-env sharing would break session/token isolation — each
# env keeps its own salt.
export DRUPAL_HASH_SALT=$HASH_SALT
export DRUPAL_SITE_NAME=drupal-${ENV}.test
# DRUPAL_PATH is mount-target-relative — every host (deploy-host with
# use-env mounted, PHP fleet, nginx fleet) sees Drupal at /var/www/drupal
# regardless of which env is active. Env-awareness lives in WHICH FSx is
# mounted, not WHERE.
export DRUPAL_PATH=/var/www/drupal

# Other infrastructure endpoints (for ad-hoc / debugging)
export FSX_DNS=$FSX
export VALKEY_HOST=$VALKEY
export VALKEY_PORT=6379
export ALB_DNS=$ALB
EOF_INNER
  # 0640 root:ubuntu — the file contains a secret (DRUPAL_DB_PASS).
  # ubuntu user (operator) needs read; nobody else does.
  chown root:ubuntu "$OUT"
  chmod 0640 "$OUT"
  echo "Wrote $OUT"
done

# Pass 2: rebuild the /etc/hosts FSx block.
# FSx hostnames live in the project VPC's internal DNS resolver only —
# they do NOT resolve across VPC peering even when the
# AllowDnsResolutionFromRemoteVpc flag is set. We bridge the gap by
# maintaining a marker block in /etc/hosts mapping each deployed FSx
# hostname to its private IP.
#
# Always check all three known envs (sandbox, staging, production) so a
# partial refresh doesn't drop entries for other envs.
HOSTS_BLOCK=$(mktemp)
trap "rm -f $HOSTS_BLOCK" EXIT
for HENV in sandbox staging production; do
  HFSX=$(aws ssm get-parameter --name "/$HENV/fsx/dns-name" \
    --query 'Parameter.Value' --output text 2>/dev/null) || continue
  [ -z "$HFSX" ] && continue
  [ "$HFSX" = "None" ] && continue
  HFSX_ID=$(echo "$HFSX" | cut -d. -f1)
  HNIC=$(aws fsx describe-file-systems \
    --file-system-ids "$HFSX_ID" \
    --query 'FileSystems[0].NetworkInterfaceIds[0]' \
    --output text 2>/dev/null) || continue
  [ -z "$HNIC" ] && continue
  [ "$HNIC" = "None" ] && continue
  HIP=$(aws ec2 describe-network-interfaces \
    --network-interface-ids "$HNIC" \
    --query 'NetworkInterfaces[0].PrivateIpAddress' \
    --output text 2>/dev/null) || continue
  [ -z "$HIP" ] && continue
  [ "$HIP" = "None" ] && continue
  echo "$HIP $HFSX  # $HENV" >> "$HOSTS_BLOCK"
done

# Replace the managed block in /etc/hosts atomically
HOSTS_NEW=$(mktemp)
trap "rm -f $HOSTS_BLOCK $HOSTS_NEW" EXIT
awk '
  /# BEGIN worxco-fsx-hosts/ {skip=1; next}
  /# END worxco-fsx-hosts/ {skip=0; next}
  !skip
' /etc/hosts > "$HOSTS_NEW"
if [ -s "$HOSTS_BLOCK" ]; then
  {
    echo ""
    echo "# BEGIN worxco-fsx-hosts (managed by refresh-env-config — do not edit)"
    cat "$HOSTS_BLOCK"
    echo "# END worxco-fsx-hosts"
  } >> "$HOSTS_NEW"
  echo "Updated /etc/hosts: $(wc -l < "$HOSTS_BLOCK") FSx entries (managed block)"
else
  echo "No FSx entries to manage in /etc/hosts (no environments deployed)"
fi
mv "$HOSTS_NEW" /etc/hosts
chmod 644 /etc/hosts
